{
  "manifest_version": 3,
  "name": "Antigravity Intercom",
  "version": "1.6.2",
  "description": "Chrome como cuerpo visible de Antigravity — intercomunicador bidireccional con control total",

  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],

  "host_permissions": [
    "ws://localhost:8765/*",
    "http://localhost:8765/*",
    "<all_urls>"
  ],

  "side_panel": {
    "default_path": "side_panel/panel.html"
  },

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/context_extractor.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_title": "Antigravity Intercom",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
